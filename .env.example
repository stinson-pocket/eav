# Example environment variables for eav-automation
# WordPress REST API
WP_SITE=https://eastatlantavillage.com
WP_USER=your-wp-username
WP_APP_PASSWORD=your-application-password-or-app-password

# Slack webhook to receive reports (optional)
SLACK_WEBHOOK_URL=

# Plagiarism API (optional) - provider-specific key
PLAGIARISM_API_KEY=
PLAGIARISM_API_ENDPOINT=

# Vector DB / Semantic index (optional)
VECTOR_DB_API_KEY=
VECTOR_DB_ENDPOINT=

# Notifications (choose one or more)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_EMAIL=signup06@gmail.com

# Google Drive (optional) - service account JSON as BASE64 string and target folder id
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_FOLDER_ID=
